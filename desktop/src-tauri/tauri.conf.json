{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgSwarm Client",
  "version": "0.1.0",
  "identifier": "works.earendil.agswarm.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgSwarm Client",
        "width": 1180,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../assets/icons/app-icon.png",
      "../../assets/icons/app-icon.icns",
      "../../assets/icons/app-icon.ico"
    ]
  }
}

