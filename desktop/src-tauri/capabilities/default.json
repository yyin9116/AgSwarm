{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the main window to use core event subscriptions for pi streaming updates.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install"
  ]
}
